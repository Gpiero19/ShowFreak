# Backend API base URL.
# Leave unset in dev — Vite proxy handles /api → localhost:3001 automatically.
# In production set this to your deployed backend URL, e.g. https://api.showfreak.com
VITE_API_URL=

# Optional — get your DSN from sentry.io (free tier available)
# Must be prefixed with VITE_ to be exposed to the browser bundle
VITE_SENTRY_DSN=
