JWT_SECRET="REPLACE_ME"
JWT_EXPIRES_IN="7d"
TMDB_API_KEY="REPLACE_ME"
TMDB_BASE_URL="https://api.themoviedb.org/3"
TMDB_IMAGE_BASE="https://image.tmdb.org/t/p"
PORT=3001
NODE_ENV=development
