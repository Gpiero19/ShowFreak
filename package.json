{
  "name": "showfreak",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "src",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --workspace=src",
    "dev:backend": "npm run dev --workspace=server",
    "build": "npm run build --workspace=src && npm run build --workspace=server",
    "build:frontend": "npm run build --workspace=src",
    "build:backend": "npm run build --workspace=server",
    "test": "npm run test --workspace=server && npm run test --workspace=src",
    "test:backend": "npm run test --workspace=server",
    "test:frontend": "npm run test --workspace=src",
    "test:coverage": "npm run test:coverage --workspace=server && npm run test:coverage --workspace=src",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "clean:ports": "lsof -ti :3000,3001,5173,5174 | xargs -r kill -9",
    "dev:clean": "npm run clean:ports && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
